# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics & Tag Manager
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Integraciones externas (opcional)
INTEGRATION_PROVIDER=none
# trello | jira | both | none

# Trello
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_LIST_ID=
# Mapa listId → delivery_status, ej: {"abc123":"development","def456":"done"}
TRELLO_LIST_STATUS_MAP=
TRELLO_WEBHOOK_SECRET=

# Jira
JIRA_BASE_URL=https://tu-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task

# Notificaciones (Slack o Teams)
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# AI Microservice
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# BigQuery (server-side only)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json
