# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Pre-Entry Access Portal — optional corporate email domains (comma-separated)
# CORPORATE_EMAIL_DOMAINS=aeromexico.com,grupoaeromexico.com

# Google Analytics & Tag Manager
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Integraciones externas (opcional)
INTEGRATION_PROVIDER=none
# trello | jira | both | none

# Trello
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_LIST_ID=
# Mapa listId → delivery_status, ej: {"abc123":"development","def456":"done"}
TRELLO_LIST_STATUS_MAP=
TRELLO_WEBHOOK_SECRET=

# Jira
JIRA_BASE_URL=https://tu-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task

# Notificaciones — Slack y/o Teams (puedes usar ambos a la vez)
# Cada paso automático del agente envía un mensaje (pedido nuevo, triaje, auto-aceptación, sync Trello, pedido desde Pregúntale).
#
# --- SLACK (avisos simples) ---
# 1. https://api.slack.com/apps → Create New App → From scratch
# 2. Incoming Webhooks → Activate → Add New Webhook to Workspace
# 3. Elige el canal (#analytics-pedidos o similar) y copia la URL (https://hooks.slack.com/services/...)
SLACK_WEBHOOK_URL=
#
# --- SLACK (botones Aceptar/Rechazar cuando el agente escala) ---
# Misma app: OAuth → Bot Token Scopes chat:write → Install to Workspace
# Interactivity → Request URL: https://TU_DOMINIO/api/integrations/slack/interactions
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_CHANNEL_ID=C01234567
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=
#
# --- MICROSOFT TEAMS ---
# 1. En el canal de Teams → ⋯ → Workflows (o Conectores clásicos → Incoming Webhook)
# 2. Crea un webhook entrante y copia la URL (https://....webhook.office.com/... o logic.azure.com)
TEAMS_WEBHOOK_URL=
#
# Prueba desde Mi panel (/command-center/admin) → botón "Probar" en Slack/Teams
# También se envía aviso al cambiar el semáforo de disponibilidad en ese panel.
#
# --- POR CLIENTE (Mi perfil /perfil) ---
# Cada usuario puede configurar sus propios webhooks en el portal.
# Las URLs se guardan en Supabase (user_notification_settings) vía API — no en .env.
# Reinicia `npm run dev` después de cambiar estas variables.

# AI Microservice
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Agente de pedidos (respuesta automática + triage)
REQUEST_AGENT_ENABLED=true
REQUEST_AGENT_AUTO_ACCEPT=true
# Emails de Sergio (coma) para auto-aceptación y notificaciones internas
SERGIO_ADMIN_EMAILS=luissergio.mkt@gmail.com

# BigQuery — única fuente de datos para el orquestador IA (server-side only)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project
# Alias opcional del proyecto (si difiere del de arriba)
BIGQUERY_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json
# Datasets que la IA puede referenciar internamente (coma-separados, opcional)
BIGQUERY_DATASETS=analytics_marts,ga4_export
BIGQUERY_MART_DATASET=analytics_marts
BIGQUERY_LOCATION=US
# Tablas de marts (nombres reales en tu proyecto)
BIGQUERY_TABLE_REVENUE_DAILY=fact_revenue_daily
BIGQUERY_TABLE_CAMPAIGN_ROAS=fact_campaign_roas
# Columnas (ajusta a tu esquema)
BIGQUERY_COL_DATE=event_date
BIGQUERY_COL_REVENUE=purchase_revenue
BIGQUERY_COL_TRANSACTIONS=transactions
BIGQUERY_COL_CAMPAIGN=campaign_name
BIGQUERY_COL_ROAS=roas
# Opcional: SQL único de snapshot (solo SELECT, sin ;)
# BIGQUERY_ORCHESTRATOR_SNAPSHOT_SQL=SELECT ...
BIGQUERY_ORCHESTRATOR_MAX_ROWS=50
